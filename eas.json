{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
      },
      "env": {
        "FLUKEE_API_BASE_URL": "https://flukee-backend.onrender.com"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
      },
      "env": {
        "FLUKEE_API_BASE_URL": "https://flukee-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
