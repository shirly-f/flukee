# Backend API URL - required for sharing the app via Expo Go
# Use your Render backend URL so the app works when shared with reviewers
FLUKEE_API_BASE_URL=https://flukee-backend.onrender.com

# Optional: For physical device on same WiFi (without tunnel), use your computer's IP
# Get IP: Mac `ipconfig getifaddr en0` | Windows `ipconfig`
# FLUKEE_API_HOST=192.168.1.5
