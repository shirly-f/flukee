# Backend API URL - required for Expo Go on physical device or web deployment
# Example for production: https://flukee-backend.onrender.com
# Leave empty to use localhost (simulator/emulator only)
FLUKEE_API_BASE_URL=

# Optional: For physical device on same WiFi, use your computer's IP instead
# Get IP: Mac `ipconfig getifaddr en0` | Windows `ipconfig`
# FLUKEE_API_HOST=192.168.1.5
